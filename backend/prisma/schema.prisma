generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@map("system_events")
}
